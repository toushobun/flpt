<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://www.mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.UserDao">
	<select id="selectBuserByKwargs" resultType="Buser"
		parameterType="Buser">
		select *
		from busertable where ""=""
		<if test="uidnum != null">
			and uidnum = #{uidnum}
		</if>
		<if test="upwd != null">
			and upwd = #{upwd}
		</if>
	</select>
	<insert id="register" parameterType="Buser">
		insert into busertable (user_id,uidnum,uname,upwd,uidphoto)
		values (null,#{uidnum},#{uname},#{upwd},#{uidphoto})
	</insert>
</mapper>