<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://www.mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.AdminDao">
	<select id="selectAuserByKwargs" resultType="Auser"
		parameterType="Auser">
		select *
		from ausertable where ""=""
		<if test="aname != null">
			and aname = #{aname}
		</if>
		<if test="apwd != null">
			and apwd = #{apwd}
		</if>
	</select>
</mapper>