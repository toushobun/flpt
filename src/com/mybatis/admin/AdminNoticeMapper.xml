<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.AdminNoticeDao">
	<!-- 发布一个公告 -->
	<insert id="addNotice" parameterType="Notice">
		insert into noticetable (id,ntitle,ncontent,ntime) 
		values (null,#{ntitle},#{ncontent},now())
	</insert>
	<!-- 删除一个公告 -->
	<delete id="deleteNoticeById" parameterType="Integer">
		delete from noticetable where id = #{id}
	</delete>
	<!-- 查询一个公告 -->
	<select id="selectANoticeById"  resultType="Notice" parameterType="Integer">
		select * from noticetable where id = #{id}
	</select>
	<!-- 查询全部公告 -->
	<select id="selectNotice"  resultType="Notice" >
		select * from noticetable
	</select> 
</mapper>