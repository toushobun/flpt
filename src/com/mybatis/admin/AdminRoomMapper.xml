<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.AdminRoomDao">
	<!-- 查询全部考场 -->
	<select id="selectRoom" resultType="Room" >
		select * from roomtable
	</select>
	<!-- 模糊搜索考场 -->
	<select id="searchRoom" resultType="Room" parameterType="String">
		select * from roomtable where concat(rname, raddress, rtelnum, rpostcode) like concat('%',#{keyWord},'%')
	</select>
	<!-- 发布一个考场 -->
	<insert id="addRoom" parameterType="Room">
		insert into roomtable (room_id,rname,raddress,rtelnum,rpostcode) 
		values (null,#{rname},#{raddress},#{rtelnum},#{rpostcode})
	</insert>
	<!-- 删除一个考场 -->
	<delete id="deleteRoomByRoom_id" parameterType="Integer">
		delete from roomtable where room_id = #{room_id}
	</delete>
	<!-- 通过id查询一个考场 -->
	<select id="selectARoomByRoom_id" resultType="Room" parameterType="Integer">
		select * from roomtable where room_id = #{room_id}
	</select>
	<!-- 通过rname查询一个考场 -->
	<select id="selectARoomByRname" resultType="Room" parameterType="String">
		select * from roomtable where rname = #{rname}
	</select>
	<!-- 通过rname和id查询一个考场 -->
	<select id="selectARoomByRnameAndRoom_id" resultType="Room" parameterType="Room">
		select * from roomtable where rname = #{rname} and room_id != #{room_id}
	</select>
	<!-- 修改一个考场 -->
	<update id="updateRoom" parameterType="Room">
	    update roomtable
	    <set>
	      <if test="rname != null">
	        rname = #{rname},
	      </if>
	      <if test="raddress != null">
	        raddress = #{raddress},
	      </if>
	      <if test="rtelnum != null">
	        rtelnum = #{rtelnum},
	      </if>
	      <if test="rpostcode != null">
	        rpostcode = #{rpostcode},
	      </if>
	    </set>
    	where room_id = #{room_id}
  	</update>
	<!-- 通过id查询一个考场 -->
	<select id="selectATestinfo__roomByRoom_id" resultType="Room" parameterType="Integer">
		select * from testinfo__room where room_id = #{room_id}
	</select>
	<!-- 查询未被选的考场 -->
	<select id="selectRoomByTestinfo_id" resultType="testinfo__room" parameterType="Integer">
		select * from roomtable where roomtable.room_id not in (select room_id from testinfo__room where testinfo_id=#{testinfo_id})
	</select>
</mapper>