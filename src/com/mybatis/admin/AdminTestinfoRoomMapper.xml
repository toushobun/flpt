<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://www.mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.AdminTestinfoRoomDao">
	<select id="selectTestinfoRoomByKwargs"
		resultType="Testinfo__room" parameterType="Testinfo__room">
		select * from testinfo__room, roomtable where roomtable.room_id =
		testinfo__room.room_id and ""=""
		<if test="testinfo_id != null">
			and testinfo_id = #{testinfo_id}
		</if>
	</select>
</mapper>